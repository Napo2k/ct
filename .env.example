# ClaudeTrader environment — copy to .env and fill in. NEVER commit .env.
# Real environment variables always take precedence over this file.

# --- Credentials -------------------------------------------------------------
# Claude API key (reasoning layer, verifier, post-mortems)
ANTHROPIC_API_KEY=

# OANDA v20 API — account portal -> Manage API Access
OANDA_API_TOKEN=
# e.g. 101-004-1234567-001
OANDA_ACCOUNT_ID=

# --- Mode flags (optional overrides; config/cycle.json is the default) -------
# EXECUTION_MODE=true
# MOCK_MODE=false
# MOCK_LLM=false

# Phase 2 live trading requires this AND live_confirmation in config/cycle.json
# LIVE_TRADING=true
